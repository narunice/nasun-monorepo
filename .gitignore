**/cdk.out/

# Local backup directory (note: _backup/ is already covered above)
backup/

# Data export folders (place ad-hoc CSV/JSON exports here)
exports/
data-exports/

# nginx infra secrets (rendered into snapshots at deploy time)
infra/nginx/secrets.env

# Deploy staging area (rsynced build trees + node_modules)
.deploy-stage/

# Ad-hoc security review reports emitted at repo root
/SECURITY_FIX_GUIDE.md
/SECURITY_REVIEW_*.md

# Internal operations docs and handoffs (live in narunice/nasun-ops)
