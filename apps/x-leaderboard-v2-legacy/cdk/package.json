{
  "name": "@nasun/x-leaderboard-cdk",
  "version": "1.0.0",
  "bin": {
    "cdk": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc",
    "build:lambdas": "cd lambda-src/x-leaderboard && node build.js",
    "build:all": "pnpm run build:lambdas && pnpm run build",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:dev": "NODE_ENV=development cdk deploy --require-approval broadening",
    "deploy:prod": "NODE_ENV=production cdk deploy --require-approval broadening"
  },
  "devDependencies": {
    "@types/node": "22.7.9",
    "aws-cdk": "2.1026.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "aws-cdk-lib": "2.211.0",
    "constructs": "^10.0.0",
    "dotenv": "^17.2.2"
  }
}
