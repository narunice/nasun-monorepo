# Enclave Dockerfile (Local Simulation)
# For production Nitro Enclave, use Dockerfile.nitro instead
# This Dockerfile is for local TCP-based simulation

FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package.json ./
COPY tsconfig.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY src/ ./src/

# Build TypeScript
RUN npm run build

# Expose the Enclave port (vsock simulation via TCP)
EXPOSE 5050

# Run the Enclave
CMD ["node", "dist/enclave/main.js"]
