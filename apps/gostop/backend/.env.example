# Gostop backend (Tier 0+) environment variables.
# Copy to .env (NOT checked in). Production .env lives on prod EC2; staging on staging EC2.

# -----------------------------------------------------------------------------
# Database (shared nasun_points instance, isolated gostop schema + roles)
# -----------------------------------------------------------------------------
# Writer: indexer writes to gostop.* tables. NO access to public schema.
GOSTOP_DATABASE_URL=postgres://gostop_writer:CHANGE_ME@localhost:5432/nasun_points

# Reader: API server. Read gostop.* + selective public.* (activity_points,
# identity_to_wallet_map, nft_health_state, user_active_missions) for
# ecosystem-points cross-references on User Dashboard.
GOSTOP_READ_URL=postgres://gostop_reader:CHANGE_ME@localhost:5432/nasun_points

# Connection pool max (gostop_writer LIMIT 20 / gostop_reader LIMIT 30 — keep below).
GOSTOP_DB_POOL_MAX=10

# -----------------------------------------------------------------------------
# Sui RPC (Nasun devnet)
# -----------------------------------------------------------------------------
SUI_RPC_URL=https://rpc.devnet.nasun.io
RPC_CONCURRENCY=10
RPC_RETRY_MAX=3

# -----------------------------------------------------------------------------
# Contract package IDs (read from packages/devnet-config/devnet-ids.json at boot)
# Override here only for local dev / testing.
# -----------------------------------------------------------------------------
# BANKROLL_POOL_PACKAGE_ID=0x...
# LOTTERY_PACKAGE_ID=0x...
# CRASH_PACKAGE_ID=0x...

# -----------------------------------------------------------------------------
# API server
# -----------------------------------------------------------------------------
API_PORT=3201
API_CORS_ORIGIN=https://gostop.app,https://staging.gostop.app,http://localhost:5180

# JWT signing key for wallet-signature auth (Tier 0.3).
# Rotate periodically. Generate: openssl rand -base64 32
AUTH_JWT_SECRET=CHANGE_ME_AT_LEAST_32_BYTES_RANDOM
AUTH_JWT_TTL_SECONDS=3600
# Re-bind JWT to client IP; invalidate on mismatch (Tier 0.3 review boost).
AUTH_BIND_IP=true

# -----------------------------------------------------------------------------
# Feed thresholds
# -----------------------------------------------------------------------------
# Whale feed: emit when bet_amount OR payout reaches threshold (USDC 6 decimals).
WHALE_BET_THRESHOLD_RAW=100000000
WHALE_PAYOUT_THRESHOLD_RAW=500000000
STREAK_FEED_MIN=5

# WS feed (PR2). FEED_ENABLED toggles both the LISTEN bridge and the
# /api/gostop/feed/* WS routes (kill-switch for incidents).
FEED_ENABLED=true
FEED_PG_CHANNEL=gostop_feed
FEED_RING_SIZE=20
# Salt for anon_id derivation in visibility-mask. Generate ONCE:
#   openssl rand -hex 32
# Required in production (NODE_ENV=production OR GOSTOP_REQUIRE_PROD_SALT=1):
# must be >= 32 chars, must not equal "fallback-anon-salt", boot fails
# otherwise. NEVER ROTATE. Every published anon_id is derived from this salt,
# so a change re-pseudonymizes every anonymous player and breaks the grouping
# contract documented in src/api/lib/visibility-mask.ts. Empty in dev falls
# back to AUTH_JWT_SECRET or a known literal.
FEED_ANON_SALT=

# Force production-grade FEED_ANON_SALT enforcement even when NODE_ENV is
# not 'production' (e.g. pm2 didn't export it). Belt-and-suspenders so a
# missing NODE_ENV can't silently fail-open to the dev fallback salt.
GOSTOP_REQUIRE_PROD_SALT=

# -----------------------------------------------------------------------------
# Explorer API (live ecosystem scores + Nasun profile data)
# Optional: when set, /me/profile returns live points instead of daily snapshot.
# -----------------------------------------------------------------------------
# explorer-api and gostop-backend are co-located on node-3 (__INDEXER_NODE_HOST__).
# Use localhost; the public DNS explorer-api.nasun.io does NOT exist (NXDOMAIN).
EXPLORER_API_URL=http://localhost:3200

# -----------------------------------------------------------------------------
# Alerts (Tier 0.2 sanity warnings, commit-verify failures)
# -----------------------------------------------------------------------------
# Reuse explorer-api Telegram channel (set on prod EC2 ~/explorer-api/.env).
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# -----------------------------------------------------------------------------
# Operational windows (UTC, off-peak refresh)
# -----------------------------------------------------------------------------
MATVIEW_REFRESH_INTERVAL_MIN=10
MATVIEW_REFRESH_OFF_PEAK_START_HOUR=3
MATVIEW_REFRESH_OFF_PEAK_END_HOUR=4
