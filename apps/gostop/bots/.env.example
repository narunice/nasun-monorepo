# GoStop Lottery Keeper environment.
# Copy to apps/gostop/bots/.env and fill in the admin key.

# Admin private key (suiprivkey... or 64 hex chars). Owns the v3 LotteryAdminCap.
LOTTERY_ADMIN_KEY=

# Network (defaults baked into lib/lottery-config.ts; uncomment to override)
# NASUN_RPC_URL=https://rpc.devnet.nasun.io
# NASUN_FAUCET_URL=https://faucet.devnet.nasun.io

# v3 contract IDs (defaults already match apps/gostop/devnet-ids.json;
# override only if redeploying)
# LOTTERY_PACKAGE_ID=0x48e23db58f02f077b46aef98aa0fcfce86aaa65046fdc7e0db302a6fc670ec14
# LOTTERY_REGISTRY_ID=0xf09e32ed9033a4ebf86b66246efb21ab618c96e9ab0032859dc926d6d9b52ea5
# LOTTERY_ADMIN_CAP_ID=0x73ae9d42b41d97f78c7bfacbf603ba13333e976dd50e7f55b2a3c029b70c262a
# BANKROLL_POOL_ID=0xf74e8c3c16ee077651f82459f350e96027c82319686395679d10f08ed0cd306d

# Schedule (defaults: close Monday 00:00 UTC, draw immediately)
# LOTTERY_CLOSE_DAY=1
# LOTTERY_CLOSE_HOUR=0
# LOTTERY_DRAW_OFFSET_MS=0
