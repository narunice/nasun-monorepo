    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "@mysten/sui": "^1.0.0",
    "@noble/ed25519": "^2.0.0",
    "alchemy-sdk": "^3.0.0",
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
