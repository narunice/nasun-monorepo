{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": ".",
    "typeRoots": ["./node_modules/@types"],
    "types": ["node", "aws-lambda"]
  },
  "include": ["index.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}