# =================================================================================
# NASUN Website - CDK Environment Variables Template
# =================================================================================
# 이 파일을 복사하여 .env, .env.development, .env.production 생성
#
# 사용법:
#   cp .env.example .env
#   cp .env.example .env.development
#   cp .env.example .env.production
#
# 그 다음 각 파일을 환경에 맞게 수정하세요.
# =================================================================================

# AWS Configuration
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# Target Account
X_TARGET_USERNAME=YOUR_TARGET_USERNAME
X_TARGET_USER_ID=YOUR_TARGET_USER_ID
TARGET_USERNAME=YOUR_TARGET_USERNAME
TARGET_USER_ID=YOUR_TARGET_USER_ID

# Secrets Manager
TWITTER_TOKENS_SECRET_NAME=nasun-twitter-tokens-dev

# API Gateway
API_GATEWAY_ID=YOUR_API_GATEWAY_ID
API_GATEWAY_STAGE=prod

# OAuth 2.0
OAUTH2_CLIENT_ID=YOUR_OAUTH2_CLIENT_ID
OAUTH2_CLIENT_SECRET=YOUR_OAUTH2_CLIENT_SECRET
OAUTH2_REDIRECT_URI=http://localhost:5174/callback

# Twitter API
TWITTER_CLIENT_ID=YOUR_TWITTER_CLIENT_ID
TWITTER_CLIENT_SECRET=YOUR_TWITTER_CLIENT_SECRET
TWITTER_BEARER_TOKEN=YOUR_TWITTER_BEARER_TOKEN

# Scoring Weights
SCORE_WEIGHT_LIKES=0.2
SCORE_WEIGHT_REPLIES=0.4
SCORE_WEIGHT_REPOSTS=0.4
SCORE_WEIGHT_QUOTES=0.6
SCORE_WEIGHT_MENTIONS=0.5

# Logging
LOG_LEVEL=INFO
ENABLE_DETAILED_LOGGING=true
