# =================================================================================
# NASUN Website - CDK Environment Variables Template
# =================================================================================
# Copy this file to create environment-specific configs:
#   cp .env.example .env.development   (dev account: __AWS_DEV_ACCOUNT__)
#   cp .env.example .env.production    (prod account: __AWS_PROD_ACCOUNT__)
#
# IMPORTANT: Sensitive credentials (Twitter API tokens, OAuth2 secrets,
# wallet proof secrets) are stored in AWS Secrets Manager, NOT in env vars.
# Only the secret *names* are configured here.
# =================================================================================

# AWS Configuration
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=YOUR_AWS_ACCOUNT_ID

# Cognito Identity Pool
VITE_COGNITO_IDENTITY_POOL_ID=YOUR_COGNITO_IDENTITY_POOL_ID

# Target Account (Single - for Leaderboard)
X_TARGET_USERNAME=YOUR_TARGET_USERNAME
X_TARGET_USER_ID=YOUR_TARGET_USER_ID
TARGET_USERNAME=YOUR_TARGET_USERNAME
TARGET_USER_ID=YOUR_TARGET_USER_ID

# Target Accounts (Multiple - for Follower Collection)
# JSON array of target accounts to track followers
TARGET_ACCOUNTS='[{"userId":"YOUR_USER_ID_1","username":"YOUR_USERNAME_1"},{"userId":"YOUR_USER_ID_2","username":"YOUR_USERNAME_2"}]'

# --- Secrets Manager References (secret names, NOT actual secrets) ---
# Dev: nasun-twitter-tokens / nasun-wallet-proof
# Prod: nasun-twitter-tokens-prod / nasun-wallet-proof-prod
TWITTER_TOKENS_SECRET_NAME=nasun-twitter-tokens
WALLET_PROOF_SECRET_NAME=nasun-wallet-proof

# API Gateway
API_GATEWAY_ID=YOUR_API_GATEWAY_ID
API_GATEWAY_STAGE=prod

# NFT Event Target Tweet
X_TARGET_TWEET_ID=YOUR_TARGET_TWEET_ID

# Scoring Weights
SCORE_WEIGHT_LIKES=0.2
SCORE_WEIGHT_REPLIES=0.4
SCORE_WEIGHT_REPOSTS=0.4
SCORE_WEIGHT_QUOTES=0.6
SCORE_WEIGHT_MENTIONS=0.5

# Logging
LOG_LEVEL=INFO
ENABLE_DETAILED_LOGGING=true
