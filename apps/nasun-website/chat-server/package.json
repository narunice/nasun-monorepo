{
  "name": "@nasun/nasun-chat-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @nasun/profile-core build && tsc && node --env-file=.env dist/server.js",
    "start": "node dist/server.js",
    "build": "pnpm --filter @nasun/profile-core build && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/client-ssm": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "@mysten/bcs": "^1.9.2",
    "@mysten/sui": "^1.45.0",
    "@nasun/baram-sdk": "workspace:*",
    "@nasun/profile-core": "workspace:*",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^11.7.0",
    "ulid": "^3.0.2",
    "undici": "^6.25.0",
    "ws": "^8.20.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  }
}
