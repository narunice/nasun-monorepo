# =================================================================================
# NASUN 프론트엔드 개발 환경 설정 (Development Environment)
# =================================================================================
# 이 파일은 로컬 개발 환경(localhost:5174)에서 사용되는 환경변수입니다.
# Vite 빌드 시스템에서 VITE_ 접두사를 가진 변수들만 클라이언트에 노출됩니다.
#
# 개발팀 주의사항:
# - 민감한 정보는 절대 클라이언트에 노출되지 않도록 주의
# - API 키는 읽기 전용이거나 개발 전용 키만 사용
# - 모든 URL은 HTTPS 사용 (로컬 개발 제외)
# =================================================================================

# ---------------------------------------------------------------------------------
# 🌐 블록체인 네트워크 설정
# ---------------------------------------------------------------------------------
# 개발 환경에서 사용할 블록체인 네트워크 (testnet/mainnet)
# 개발 중에는 testnet을 사용하여 안전하게 테스트
VITE_NETWORK=testnet

# ---------------------------------------------------------------------------------
# ☁️ AWS 서비스 연동 설정
# ---------------------------------------------------------------------------------
# AWS 리전 설정 (백엔드 Lambda 함수들과 동일한 리전)
VITE_AWS_REGION=ap-northeast-2

# AWS Cognito 사용자 인증 풀 설정
# 사용자 회원가입, 로그인, 비밀번호 관리 등에 사용
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_sfCoAnBEx
VITE_COGNITO_CLIENT_ID=6i40se5u05emg6e8krvs4jig37
VITE_COGNITO_DOMAIN=signin.auth.ap-northeast-2.amazoncognito.com

# AWS Cognito Identity Pool (임시 AWS 자격 증명 발급용)
# 소셜 로그인 후 AWS 리소스에 접근할 때 사용
VITE_COGNITO_IDENTITY_POOL_ID=ap-northeast-2:cea43281-b7c1-4473-8cbf-cf5ccaa33c0a

# ---------------------------------------------------------------------------------
# 🔐 소셜 로그인 설정 (OAuth 2.0)
# ---------------------------------------------------------------------------------
# Google OAuth 클라이언트 ID (Google 계정으로 로그인 기능)
# Google Cloud Console에서 발급받은 웹 애플리케이션용 클라이언트 ID
VITE_GOOGLE_CLIENT_ID=869935693878-o7ln8iu737ia6a6ujsfrjineh94k5ubh.apps.googleusercontent.com

# X(Twitter) OAuth 클라이언트 ID (X 계정으로 로그인 기능)
# X Developer Portal에서 발급받은 OAuth 2.0 클라이언트 ID
# 리더보드 시스템과 연동하여 사용자의 X 활동을 추적
VITE_TWITTER_CLIENT_ID=TkoxejE3ZjhpNXBGdlhsV01RajM6MTpjaQ

# Twitter OAuth 2.0 Authentication API
VITE_TWITTER_AUTH_API=https://hal8k5h3zl.execute-api.ap-northeast-2.amazonaws.com/prod/auth/twitter

# MetaMask Ethereum Wallet Login (Development - Sepolia Testnet)
# MetaMask Auth API (deployed on 2025-10-22)
VITE_ENABLE_METAMASK_LOGIN=true
VITE_ETHEREUM_CHAIN_ID=11155111
VITE_ETHEREUM_NETWORK_NAME=Sepolia
VITE_METAMASK_AUTH_API=https://suc4mh7on9.execute-api.ap-northeast-2.amazonaws.com/prod/auth/metamask

# ---------------------------------------------------------------------------------
# 🔒 Content Security Policy (CSP) - 웹 보안 설정
# ---------------------------------------------------------------------------------
# CSP는 XSS, 클릭재킹 등의 공격을 방지하기 위한 브라우저 보안 정책입니다.
# vite.config.ts에서 이 환경 변수를 읽어 HTML <meta> 태그에 주입합니다.
#
# 도메인별 용도:
# - *.nasun.io, *.nasun.xyz: NASUN 웹사이트 및 API
# - *.moonoak.io, *.gensol.io: 파트너 프로젝트 연동
# - *.amazoncognito.com, *.amazonaws.com: AWS 인증 및 API Gateway
# - accounts.google.com, oauth2.googleapis.com: Google OAuth 로그인
# - api.twitter.com, twitter.com, x.com: X(Twitter) OAuth 로그인
# - eth-sepolia.g.alchemy.com: Ethereum NFT 조회 (Alchemy API - Sepolia Testnet)
# - api-sepolia.etherscan.io: Ethereum 트랜잭션 조회 (Etherscan API - Sepolia Testnet)
# - fullnode.testnet.sui.io, api.testnet.iota.cafe: 블록체인 테스트넷 연동
#
# ⚠️ 주의: 새로운 외부 API를 사용할 때는 해당 도메인을 connect-src에 추가해야 합니다.
# 추가 방법은 doc/CSP_CONFIGURATION_GUIDE.md를 참고하세요.
VITE_CSP_POLICY=default-src 'self'; connect-src 'self' https://cdn.jsdelivr.net https://*.nasun.io https://*.nasun.xyz https://*.moonoak.io https://staging.moonoak.io https://cms.moonoak.io https://*.gensol.io https://*.genspectra.io https://fullnode.testnet.sui.io https://api.testnet.iota.cafe wss://api.testnet.iota.cafe https://indexer.testnet.iota.cafe https://graphql.testnet.iota.cafe https://faucet.testnet.iota.cafe https://*.amazoncognito.com https://*.amazonaws.com https://cognito-idp.ap-northeast-2.amazonaws.com https://signin.auth.ap-northeast-2.amazoncognito.com https://accounts.google.com https://oauth2.googleapis.com https://api.twitter.com https://twitter.com https://x.com https://eth-sepolia.g.alchemy.com https://api-sepolia.etherscan.io; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://use.typekit.net https://p.typekit.net; font-src 'self' data: https://use.typekit.net https://cdn.jsdelivr.net;

# ---------------------------------------------------------------------------------
