# Free tier: 300M compute units/month (sufficient for most use cases)
VITE_ALCHEMY_API_KEY=C0BAvKSdKL-OxV-rNi88V
VITE_ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/
VITE_ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/

# Etherscan API (Backup - Fallback when Alchemy fails)
