flowchart TD
    Start(( )) --> Pending
    Pending --> Executing
    Pending --> Cancelled
    Executing --> Completed
    Executing --> TimedOut
    Completed --> End(( ))
    Cancelled --> End
    TimedOut --> End

    Pending(["STATUS 0<br/>NUSDC locked in escrow"])
    Executing(["STATUS 1<br/>TEE processing (5min timeout)"])
    Completed(["STATUS 2<br/>Settlement complete (+20 rep)"])
    Cancelled(["STATUS 3<br/>User cancelled (full refund)"])
    TimedOut(["STATUS 4<br/>Executor failed (-30 rep)"])

    style Pending fill:#e3f2fd,stroke:#1565c0
    style Executing fill:#fff3e0,stroke:#e65100
    style Completed fill:#e8f5e9,stroke:#2e7d32
    style Cancelled fill:#f3f4f6,stroke:#6b7280
    style TimedOut fill:#fce4ec,stroke:#c62828
