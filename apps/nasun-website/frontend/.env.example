# Copy to .env.development / .env.staging / .env.production and fill in values.
# VITE_* vars are embedded into the client bundle at build time.

# Feature Flags
# Set to 'true' to enable the Nasun AI section (my-account AI tab + /ecosystem/nasun-ai route).
# Staging: true  |  Production: false (until public launch)
VITE_NASUN_AI_ENABLED=false
