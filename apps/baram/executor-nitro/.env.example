# Baram TEE Executor Environment Variables

# --- Enclave Connection ---
# Required on Nitro instances (vsock mode)
USE_VSOCK=true
ENCLAVE_CID=16

# Optional: Enclave address (for local TCP simulation)
ENCLAVE_HOST=localhost
ENCLAVE_PORT=5050

# Optional: Host HTTP server port
HOST_PORT=3000

# --- AI Provider Keys ---
# At least one is required for Direct mode.
# Both can be set simultaneously for multi-provider support.

# OpenAI API key
OPENAI_API_KEY=

# Groq API key (OpenAI-compatible, free tier available)
GROQ_API_KEY=

# --- On-chain Settlement (Sui) ---
# Required for settlement + compliance record creation.
# If not set, Host will return results without on-chain settlement.

# Sui RPC endpoint
SUI_RPC_URL=https://rpc.devnet.nasun.io

# Baram escrow contract
BARAM_PACKAGE_ID=
BARAM_REGISTRY_ID=

# Executor private key (hex format)
EXECUTOR_PRIVATE_KEY=

# AER (AI Execution Report) contract
AER_PACKAGE_ID=
AER_REGISTRY_ID=

# Executor Registry (for reputation/stats lookup)
EXECUTOR_REGISTRY_ID=

# Attestation contract (for PCR baseline verification)
ATTESTATION_PACKAGE_ID=
ATTESTATION_REGISTRY_ID=

# Staking Registry (for stake amount lookup)
STAKING_REGISTRY_ID=

# Tier Registry (for executor tier lookup)
TIER_REGISTRY_ID=

# --- Phase F-2: Self-Service (record_job_completion + refresh_tier_from_state) ---
# Executor package ID (baram_executor)
EXECUTOR_PACKAGE_ID=

# ProcessedRequests shared object ID (dedup guard for record_job_completion)
PROCESSED_REQUESTS_ID=

# ExecutorStake owned object ID (required for refresh_tier_from_state)
EXECUTOR_STAKE_ID=

# --- Plan B (capability + atomic settlement) ---
# Capability registry (marker shared object) — lives in baram_aer package.
CAPABILITY_REGISTRY_ID=

# Agent Profile (Plan B B1 republish)
AGENT_PACKAGE_ID=
AGENT_PROFILE_REGISTRY_ID=

# Pado DeepBook package id (action-classes.json substitution target).
PADO_DEEPBOOK_PACKAGE_ID=

# Token TypeName strings (action-classes.json substitution targets). Format:
# `<package_id>::<module>::<TYPE>`. The host refuses to boot if any of these
# is missing while action-classes.json references it.
NBTC_TYPE=
NUSDC_TYPE=
NASUN_TYPE=

# Plan B §4.5: per-wallet daily cognition payout cap. 0 = off (default).
# Set to N to refuse a new cognition-only PTB once N payouts have landed in
# the last 24h. Defense against a runaway agent that drains Budget via
# cognition AERs without ever emitting an execution AER.
DAILY_COGNITION_PAYOUT_CAP=0
