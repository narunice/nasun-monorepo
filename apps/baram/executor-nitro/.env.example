# Baram TEE Executor Environment Variables

# --- Enclave Connection ---
# Required on Nitro instances (vsock mode)
USE_VSOCK=true
ENCLAVE_CID=16

# Optional: Enclave address (for local TCP simulation)
ENCLAVE_HOST=localhost
ENCLAVE_PORT=5050

# Optional: Host HTTP server port
HOST_PORT=3000

# --- On-chain Settlement (Sui) ---
# Required for settlement + compliance record creation.
# If not set, Host will return results without on-chain settlement.

# Sui RPC endpoint
SUI_RPC_URL=https://rpc.devnet.nasun.io

# Baram escrow contract
BARAM_PACKAGE_ID=
BARAM_REGISTRY_ID=

# Executor private key (suiprivkey1q... format)
EXECUTOR_PRIVATE_KEY=

# Compliance (ExecutionComplianceRecord) contract
COMPLIANCE_PACKAGE_ID=
COMPLIANCE_REGISTRY_ID=

# Executor Registry (for reputation/stats lookup)
EXECUTOR_REGISTRY_ID=

# Attestation contract (for PCR baseline verification)
ATTESTATION_PACKAGE_ID=
ATTESTATION_REGISTRY_ID=

# Staking Registry (for stake amount lookup)
STAKING_REGISTRY_ID=

# Tier Registry (for executor tier lookup)
TIER_REGISTRY_ID=
