{
  "$comment": "Plan C C3-v2 static action-class registry (§4.5). Per-function entries declare the Move signature shape the host PTB builder relies on: which arg positions take the withdraw_coin / zero_deep pipes, which 3-coin return position is the swap's primary output vs leftover input / leftover DEEP, and which input/output asset TypeNames the host preflight will accept. Strings prefixed with $ are env vars resolved at boot.",

  "trade.swap.v1": {
    "targets": [
      {
        "package": "$PADO_DEEPBOOK_PACKAGE_ID",
        "module": "pool",
        "functions": [
          {
            "name": "swap_exact_quote_for_base",
            "direction": "BUY",
            "typeArgs": ["base", "quote"],
            "inputCoinArg": 1,
            "deepCoinArg": 2,
            "minOutArg": 3,
            "outputCoinResult": {
              "primary": 0,
              "leftoverInput": 1,
              "leftoverDeep": 2
            },
            "allowedInputAssets": ["$NUSDC_TYPE"],
            "allowedOutputAssets": ["$NBTC_TYPE"],
            "poolId": "$PADO_NBTC_NUSDC_POOL"
          },
          {
            "name": "swap_exact_base_for_quote",
            "direction": "SELL",
            "typeArgs": ["base", "quote"],
            "inputCoinArg": 1,
            "deepCoinArg": 2,
            "minOutArg": 3,
            "outputCoinResult": {
              "primary": 1,
              "leftoverInput": 0,
              "leftoverDeep": 2
            },
            "allowedInputAssets": ["$NBTC_TYPE"],
            "allowedOutputAssets": ["$NUSDC_TYPE"],
            "poolId": "$PADO_NBTC_NUSDC_POOL"
          }
        ]
      }
    ],
    "deepType": "$PADO_DEEP_TYPE"
  }
}
