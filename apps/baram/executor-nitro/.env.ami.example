# Baram TEE Spot Instance Configuration
# Copy to .env.ami and fill in values
#
# Usage:
#   cp .env.ami.example .env.ami
#   # Edit .env.ami with your values
#   ./scripts/launch-spot.sh

# ==============================================
# AMI Configuration
# ==============================================

# AMI ID (create with ./scripts/create-ami.sh)
# After creating AMI, run: aws ec2 describe-images --image-ids <AMI_ID> --query 'Images[0].State'
# Wait for 'available' status before using
BARAM_AMI_ID=ami-xxxxxxxxxxxxxxxxx

# ==============================================
# AWS Resources
# ==============================================

# EC2 Key Pair name (for SSH access)
# Create with: aws ec2 create-key-pair --key-name baram-nitro --query 'KeyMaterial' --output text > ~/.ssh/baram-nitro.pem
BARAM_KEY_NAME=baram-nitro

# Security Group ID (must allow ports 22, 3000)
# Create with:
#   SG_ID=$(aws ec2 create-security-group --group-name baram-tee-dev --description "Baram TEE Dev" --query 'GroupId' --output text)
#   aws ec2 authorize-security-group-ingress --group-id $SG_ID --protocol tcp --port 22 --cidr 0.0.0.0/0
#   aws ec2 authorize-security-group-ingress --group-id $SG_ID --protocol tcp --port 3000 --cidr 0.0.0.0/0
BARAM_SECURITY_GROUP=sg-xxxxxxxxxxxxxxxxx

# Subnet ID (optional - leave empty for default VPC)
# Specify if you need a specific subnet or availability zone
BARAM_SUBNET_ID=

# ==============================================
# Instance Configuration
# ==============================================

# Instance type (must support Nitro Enclaves)
# Recommended: r6i.xlarge (4 vCPU, 32GB RAM, ~$0.05/hr Spot)
# Minimum: r6i.large (2 vCPU, 16GB RAM) - may be tight on memory
BARAM_INSTANCE_TYPE=r6i.xlarge

# Maximum Spot price ($/hr)
# Check current prices: https://aws.amazon.com/ec2/spot/pricing/
# r6i.xlarge ap-northeast-2: ~$0.04-0.06/hr Spot
BARAM_SPOT_PRICE=0.10

# ==============================================
# Git Configuration
# ==============================================

# Git branch to checkout (default: feat/wallet-ui-reorganization)
# Set to 'main' for production or your feature branch for development
BARAM_BRANCH=feat/wallet-ui-reorganization
