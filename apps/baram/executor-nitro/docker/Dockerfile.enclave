# Enclave Dockerfile
# In production, this would be built as a Nitro Enclave image (EIF)
# For local simulation, we use a standard Node.js container

FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package.json ./
COPY tsconfig.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY src/ ./src/

# Build TypeScript
RUN npm run build

# Expose the Enclave port (vsock simulation via TCP)
EXPOSE 5050

# Run the Enclave
CMD ["node", "dist/enclave/main.js"]
