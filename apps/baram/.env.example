VITE_EXECUTOR_ADDRESS=0xa952b023c471e51457eb71b5c9e7424f0799103fc2336d79c0ffc2164c5ca854

# Executor Registry — reads from @nasun/devnet-config (single registry)
# Do NOT add VITE_EXECUTOR_PACKAGE_ID or VITE_EXECUTOR_REGISTRY_ID here.
# network.ts reads directly from devnet-config.

