VITE_NETWORK_NAME=Nasun Devnet
VITE_CHAIN_ID=12bf3808
VITE_FAUCET_URL=https://faucet.devnet.nasun.io

# zkLogin (Google OAuth)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_ZKLOGIN_SALT_API_URL=https://your-salt-api.amazonaws.com/prod
VITE_ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1

# Tokens (from devnet_tokens - unified across all apps)
VITE_NUSDC_TYPE=0x10748ed4f5063ca4a564fdfecc289954d14efa1a209e7292dcc18d65b2cb4017::nusdc::NUSDC

# Baram Contract (deployed 2026-01-27 - using devnet_tokens)
VITE_BARAM_PACKAGE_ID=0xfbe120e1847ca3ce7968bc7d85504a202639666755d581cfe642df3e57b2bc2f
VITE_BARAM_REGISTRY_ID=0x52427e24315a444e9aa07ecb93df5a3392e1cb5d5bec8aba90c4c9eecaf77d3f
VITE_BARAM_UPGRADE_CAP=0xa9a6ee0412639af01e630ce23d38b246a88bdfd3ee8db5e3634ce45fa1eefe62

