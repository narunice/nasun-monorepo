{
  "name": "baram-executor",
  "version": "1.0.0",
  "description": "Baram AI Executor Lambda - Processes AI requests and submits proofs on-chain",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk/*",
    "build:tsc": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.995.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.1047.0",
    "@aws-sdk/lib-dynamodb": "^3.995.0",
    "@mysten/sui": "^1.0.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.2",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
