# Baram Agent Runner — Environment Configuration
#
# WARNING: AGENT_PRIVATE_KEY can access funds connected to this agent's Budget.
# Never commit this file to git.

# Supports: Bech32 (suiprivkey1q...), hex (0x... or 64 hex chars), or base64
# Export from Dashboard: Agent Detail > "Export Key for Agent Runner"
AGENT_PRIVATE_KEY=suiprivkey1q...

# Baram contract settings
BARAM_PACKAGE_ID=0x949af600b619785b66fe7959afb7f814ce8952dad301377de80343b90a8722f9
BARAM_REGISTRY_ID=0x509825058d4a537d3e9dfea39120077c02c1cf68f8b33969689017ae97c8e833
BUDGET_ID=0x...

# Executor settings
LAMBDA_URL=https://...execute-api.ap-northeast-2.amazonaws.com/prod
BARAM_API_KEY=...
EXECUTOR_ADDRESS=0x...

# Agent behavior
MODEL=llama-3.3-70b-versatile
PRESET=research
RPC_URL=https://rpc.devnet.nasun.io

# Per-request price in NUSDC (6 decimals). Default: 1000000 = 1 NUSDC
# PRICE=1000000

# Override interval (minimum 5 minutes). Defaults per preset:
#   research=30, content=1440, analysis=1440
# INTERVAL_MINUTES=15
